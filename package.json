{
  "name": "mygamelist",
  "version": "2.0.0",
  "description": "Application for managing video game lists with GitHub Gist synchronization",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "validate": "node scripts/ci-validate.js && html-validate index.html && eslint src tests",
    "test": "vitest run tests/unit src",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests --fix"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@tanstack/react-virtual": "^3.13.24",
    "firebase": "^12.13.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.9.5"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/parser": "^8.59.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "html-validate": "^10.13.1",
    "jsdom": "^29.0.2",
    "sass": "^1.99.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}
