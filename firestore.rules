rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ==========================================
    // FUNCIONES GLOBALES
    // ==========================================

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email_verified == true
        && request.auth.token.email == "bellanco3@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isPlaceholder(docId) {
      return docId == "_placeholder";
    }

    // C5/T4 — Validación de esquema (allowlist) de escrituras: un cliente hostil autenticado no puede
    // inyectar campos arbitrarios en su propio doc. hasOnly admite un subconjunto, así que las escrituras
    // parciales por merge siguen valiendo mientras no introduzcan claves fuera de la lista.
    function profileWriteIsValid() {
      return request.resource.data.uid is string
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.keys().hasOnly([
          "schemaVersion", "uid", "profileId", "email", "displayName", "photoURL", "social", "updatedAt"
        ]);
    }

    function privateConfigWriteIsValid() {
      return request.resource.data.keys().hasOnly([
        "schemaVersion", "profileId", "gamesGistId", "socialGistId", "gamesChunks", "socialChunks", "encryptedGithubToken"
      ]);
    }

    // ST9 — validación de esquema (allowlist) de userMap: un dueño no puede inyectar campos arbitrarios/payloads
    // grandes en su propio doc. Solo `profileId` + `schemaVersion`.
    function userMapWriteIsValid() {
      return request.resource.data.keys().hasOnly(["profileId", "schemaVersion"]);
    }

    // F2 — publicConfig: preferencias NO sensibles del dueño (p. ej. la escala de puntuación estrellas/nota).
    // Separada de privateConfig (token/ids) para diferenciarla. Solo `schemaVersion` + `scoreScale`.
    function publicConfigWriteIsValid() {
      return request.resource.data.keys().hasOnly(["schemaVersion", "scoreScale"])
        && (!("scoreScale" in request.resource.data)
            || request.resource.data.scoreScale in ["stars", "grade"]);
    }

    // ==========================================
    // COLECCION: PROFILES
    // ==========================================

    match /profiles/{userId} {
      // IMPORTANTE:
      // Lectura social compatible con consultas de coleccion:
      // - Admin
      // - Propietario
      // - Usuarios autenticados sobre perfiles con social.enabled == true
      //
      // Nota: Se evita condicionar la lectura con !isPlaceholder(userId)
      // para no romper consultas de coleccion (query rules inference).
      allow read: if
        isAdmin() ||
        isOwner(userId) ||
        (
          isSignedIn() &&
          resource.data.keys().hasAny(['social']) &&
          resource.data.social.enabled == true
        );

      // Crear o editar perfil propio (uid coincidente + esquema válido) o ser admin.
      allow create, update: if !isPlaceholder(userId) && (
        isAdmin() ||
        (
          isOwner(userId) &&
          profileWriteIsValid()
        )
      );

      // Solo el admin puede borrar perfiles (excepto el placeholder).
      allow delete: if !isPlaceholder(userId) && isAdmin();
    }

    // ==========================================
    // COLECCION: PRIVATE CONFIG (migración — solo el dueño)
    // Guarda ids de gist + el token de GitHub CIFRADO (recuperación cross-device).
    // El doc se identifica por el uid; nunca es legible por otros.
    // ==========================================

    match /privateConfig/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && privateConfigWriteIsValid();
    }

    // ==========================================
    // COLECCION: PUBLIC CONFIG (F2 — preferencias no sensibles del dueño)
    // Escala de puntuación (estrellas/nota) por usuario, para que le siga entre dispositivos.
    // Solo el dueño lee/escribe su propia entrada; validación de esquema por allowlist.
    // ==========================================

    match /publicConfig/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && publicConfigWriteIsValid();
    }

    // ==========================================
    // COLECCION: USER MAP (migración — mapa privado uid -> profileId)
    // Solo el dueño escribe/lee su propia entrada.
    // ==========================================

    match /userMap/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId) && userMapWriteIsValid();
    }

    // ==========================================
    // COLECCION: FRIENDSHIPS (amistad con aceptación mutua)
    // Un doc por par no ordenado, id canónico `minUid__maxUid`. Solo los participantes leen/borran.
    // Campos denormalizados: cada parte escribe SOLO los suyos (requester en create, recipient al aceptar).
    // ==========================================

    match /friendships/{docId} {
      // Solo en update/delete (operaciones sobre un doc concreto → `resource` poblado). La LECTURA no usa esta
      // función: en `list` el acceso a `resource.data` da "Null value error" y hay que evitarlo (ver `allow read`).
      function isFriendshipParticipant() {
        return isSignedIn() && request.auth.uid in resource.data.users;
      }

      // Crear petición: solo el requester, id/orden canónico, estado pending y allowlist de sus propios campos.
      function newFriendshipIsValid() {
        return request.resource.data.keys().hasOnly([
            "users", "requester", "recipient", "status", "createdAt", "updatedAt",
            "requesterName", "requesterPhoto", "requesterSocialGistId", "requesterGamesGistId"
          ])
          && request.resource.data.users.size() == 2
          && request.resource.data.users[0] < request.resource.data.users[1]
          && docId == request.resource.data.users[0] + "__" + request.resource.data.users[1]
          && request.auth.uid == request.resource.data.requester
          && request.resource.data.requester in request.resource.data.users
          && request.resource.data.recipient in request.resource.data.users
          && request.resource.data.recipient != request.resource.data.requester
          && request.resource.data.status == "pending";
      }

      // Aceptar: solo el recipient, pending -> accepted, escribiendo SOLO sus campos denormalizados + updatedAt.
      function friendshipAcceptTransition() {
        return request.auth.uid == resource.data.recipient
          && resource.data.status == "pending"
          && request.resource.data.status == "accepted"
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            "status", "updatedAt", "recipientName", "recipientPhoto", "recipientSocialGistId", "recipientGamesGistId"
          ]);
      }

      // Sanear: cada parte refresca SOLO sus propios campos denormalizados (nombre/foto), sin tocar estado/identidad.
      function friendshipHealOwnFields() {
        return request.resource.data.status == resource.data.status
          && request.resource.data.users == resource.data.users
          && request.resource.data.requester == resource.data.requester
          && request.resource.data.recipient == resource.data.recipient
          && (
            (request.auth.uid == resource.data.requester
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                "requesterName", "requesterPhoto", "requesterSocialGistId", "requesterGamesGistId", "updatedAt"]))
            ||
            (request.auth.uid == resource.data.recipient
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                "recipientName", "recipientPhoto", "recipientSocialGistId", "recipientGamesGistId", "updatedAt"]))
          );
      }

      // Lectura: admin, o participante. Sin `!isPlaceholder(docId)` (en `list` el docId no está ligado y romper el
      // acceso a `resource.data` da "Null value error" que deniega TODA la consulta del feed/bandeja). El placeholder
      // no tiene `users`, así que la consulta `array-contains` nunca lo devuelve.
      allow read:   if isAdmin() || (isSignedIn() && request.auth.uid in resource.data.users);
      allow create: if !isPlaceholder(docId) && (isAdmin() || newFriendshipIsValid());
      allow update: if !isPlaceholder(docId) && (isAdmin() || (isFriendshipParticipant() && (friendshipAcceptTransition() || friendshipHealOwnFields())));
      allow delete: if !isPlaceholder(docId) && (isAdmin() || isFriendshipParticipant()); // cancelar / rechazar / eliminar
    }

    // ==========================================
    // COLECCIONES EN FASE 1 (SOLO ADMIN)
    // ==========================================

    // Aplicable a: recommendations, activity_events
    match /recommendations/{docId} {
      allow read, write: if !isPlaceholder(docId) && isAdmin();
    }

    match /activity_events/{docId} {
      allow read, write: if !isPlaceholder(docId) && isAdmin();
    }

    // ==========================================
    // REGLA DE CIERRE
    // ==========================================

    // Denegar cualquier otro acceso no especificado explicitamente arriba
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
