VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_ENABLE_ANALYTICS=true

# GitHub OAuth App — client_id PÚBLICO (aparece en el build). Habilita el botón "Conectar con GitHub".
# Déjalo vacío para mantener solo el flujo manual de token (PAT).
VITE_GITHUB_CLIENT_ID=
# El client_secret NO va aquí. Se configura como variable/secreto del entorno de Cloudflare Pages
# (Settings → Environment variables) con el nombre GITHUB_CLIENT_SECRET, y lo lee functions/api/github-oauth.ts.
# Para desarrollo local con `wrangler pages dev`, ponlo en un fichero .dev.vars (git-ignorado):
#   GITHUB_CLIENT_ID=xxxx
#   GITHUB_CLIENT_SECRET=yyyy
